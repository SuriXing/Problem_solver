# Supabase Configuration (public — anon key is safe to expose to browser)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# DO NOT set a VITE_ variant of the service role key — it bypasses RLS and
# anything prefixed VITE_ is baked into the client bundle. Use the non-VITE
# name below only inside /api/** serverless functions.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_SERVER_ONLY

# Mentor Table cross-promo link (optional; link is hidden if unset)
VITE_MENTOR_URL=

# Mentor Table AI (server-side, e.g. Vercel project env vars)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# OpenAI-compatible providers (e.g. DashScope)
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=qwen-max
MENTOR_UPSTREAM_TIMEOUT_MS=25000

# Optional frontend override (if Vite proxy is unavailable)
VITE_MENTOR_API_URL=http://127.0.0.1:8787/api/mentor-table
VITE_MENTOR_API_TIMEOUT_MS=35000

# Email notifications (server-side, Vercel env var)
# Get a free API key at https://resend.com/api-keys — 3k emails/month free
RESEND_API_KEY=re_your_api_key_here
# Optional — defaults to onboarding@resend.dev (Resend's shared sandbox).
# For production, verify your own domain in Resend and use noreply@yourdomain.com
RESEND_FROM_ADDRESS=onboarding@resend.dev
